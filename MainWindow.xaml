<Window x:Class="PdvBasico.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="PDV Básico - Demonstração" 
        Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#1a1a1a">
    
    <Window.Resources>
        <!-- Estilos em modo escuro -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#2d2d30"/>
            <Setter Property="Foreground" Value="#ffffff"/>
            <Setter Property="BorderBrush" Value="#3e3e42"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#007acc"/>
                    <Setter Property="BorderBrush" Value="#005a9e"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2d2d30"/>
            <Setter Property="Foreground" Value="#ffffff"/>
            <Setter Property="BorderBrush" Value="#3e3e42"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#cccccc"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="5,10,5,5"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#252526"/>
            <Setter Property="Foreground" Value="#ffffff"/>
            <Setter Property="BorderBrush" Value="#3e3e42"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="#1e1e1e"/>
            <Setter Property="AlternatingRowBackground" Value="#252526"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#cccccc"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="350"/>
        </Grid.ColumnDefinitions>

        <!-- Painel Principal (Produtos/Venda) -->
        <Grid Grid.Column="0" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Cabeçalho -->
            <Border Grid.Row="0" Background="#007acc" CornerRadius="5" Padding="15" Margin="0,0,0,10">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🧾 PDV BÁSICO - SISTEMA DE VENDAS" 
                               FontSize="24" 
                               FontWeight="Bold"
                               Foreground="White"/>
                </StackPanel>
            </Border>

            <!-- Lista de Produtos -->
            <Border Grid.Row="1" BorderBrush="#3e3e42" BorderThickness="1" CornerRadius="5" Padding="10">
                <StackPanel>
                    <TextBlock Text="PRODUTOS DISPONÍVEIS" 
                               FontSize="16" 
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>
                    
                    <DataGrid x:Name="dgProdutos" 
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              Height="300">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Código" Binding="{Binding Codigo}" Width="80"/>
                            <DataGridTextColumn Header="Produto" Binding="{Binding Nome}" Width="*"/>
                            <DataGridTextColumn Header="Preço" Binding="{Binding Preco, StringFormat=C2}" Width="100"/>
                            <DataGridTextColumn Header="Estoque" Binding="{Binding Estoque}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Button x:Name="btnAdicionarProduto" 
                            Content="➕ Adicionar à Venda" 
                            Margin="0,10,0,0"
                            Click="BtnAdicionarProduto_Click"
                            Height="40"/>
                </StackPanel>
            </Border>

            <!-- Itens da Venda Atual -->
            <Border Grid.Row="2" BorderBrush="#3e3e42" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,10,0,0">
                <StackPanel>
                    <TextBlock Text="ITENS DA VENDA" 
                               FontSize="16" 
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>
                    
                    <DataGrid x:Name="dgItensVenda" 
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              Height="200">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Produto" Binding="{Binding ProdutoNome}" Width="*"/>
                            <DataGridTextColumn Header="Qtd" Binding="{Binding Quantidade}" Width="60"/>
                            <DataGridTextColumn Header="Preço Unit." Binding="{Binding PrecoUnitario, StringFormat=C2}" Width="100"/>
                            <DataGridTextColumn Header="Subtotal" Binding="{Binding Subtotal, StringFormat=C2}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Painel Lateral (Cliente/Total/Ações) -->
        <Grid Grid.Column="1" Background="#252526" Margin="0,10,10,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Cadastro de Cliente -->
            <Border Grid.Row="0" Background="#2d2d30" CornerRadius="5" Padding="15" Margin="10">
                <StackPanel>
                    <TextBlock Text="👤 CADASTRAR CLIENTE" 
                               FontSize="16" 
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>
                    
                    <Label Content="Nome:"/>
                    <TextBox x:Name="txtClienteNome"/>
                    
                    <Label Content="Telefone:"/>
                    <TextBox x:Name="txtClienteTelefone"/>
                    
                    <Label Content="Email:"/>
                    <TextBox x:Name="txtClienteEmail"/>
                    
                    <Button x:Name="btnCadastrarCliente" 
                            Content="💾 Salvar Cliente" 
                            Margin="0,10,0,0"
                            Click="BtnCadastrarCliente_Click"/>
                </StackPanel>
            </Border>

            <!-- Resumo da Venda -->
            <Border Grid.Row="1" Background="#2d2d30" CornerRadius="5" Padding="15" Margin="10">
                <StackPanel>
                    <TextBlock Text="💰 RESUMO DA VENDA" 
                               FontSize="16" 
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock Text="Total Itens:" Width="150"/>
                        <TextBlock x:Name="txtTotalItens" Text="0" FontWeight="Bold"/>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <TextBlock Text="Valor Total:" Width="150"/>
                        <TextBlock x:Name="txtValorTotal" Text="R$ 0,00" FontWeight="Bold" FontSize="16"/>
                    </StackPanel>
                    
                    <Separator Background="#3e3e42" Margin="0,15"/>
                    
                    <Label Content="Forma de Pagamento:"/>
                    <ComboBox x:Name="cbFormaPagamento"
                              Background="#2d2d30"
                              Foreground="White"
                              BorderBrush="#3e3e42"
                              Margin="0,0,0,10">
                        <ComboBoxItem Content="Dinheiro"/>
                        <ComboBoxItem Content="Cartão de Crédito"/>
                        <ComboBoxItem Content="Cartão de Débito"/>
                        <ComboBoxItem Content="PIX"/>
                    </ComboBox>
                </StackPanel>
            </Border>

            <!-- Botões de Ação -->
            <StackPanel Grid.Row="2" Margin="10">
                <Button x:Name="btnFinalizarVenda" 
                        Content="✅ FINALIZAR VENDA" 
                        Background="#28a745"
                        Click="BtnFinalizarVenda_Click"
                        Height="45"
                        FontSize="16"
                        FontWeight="Bold"/>
                
                <Button x:Name="btnCancelarVenda" 
                        Content="❌ CANCELAR VENDA" 
                        Background="#dc3545"
                        Click="BtnCancelarVenda_Click"
                        Height="45"
                        Margin="0,10,0,0"
                        FontSize="16"/>
            </StackPanel>

            <!-- Status -->
            <Border Grid.Row="3" Background="#2d2d30" CornerRadius="5" Padding="10" Margin="10">
                <TextBlock x:Name="txtStatus" 
                           Text="Pronto para vender..."
                           Foreground="#28a745"
                           TextAlignment="Center"/>
            </Border>
        </Grid>
    </Grid>
</Window>